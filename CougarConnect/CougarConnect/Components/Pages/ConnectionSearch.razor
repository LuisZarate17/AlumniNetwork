@page "/ConnectionSearch"
@attribute [StreamRendering]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using CougarConnect.Data
@using CougarConnect.Components.Account
@using CougarConnect.Models
@using CougarConnect.Services
@inject NavigationManager NavigationManager
@inject SupabaseService Supabase
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IEmailSender EmailSender
@inject ILogger<ConnectionSearch> Logger


<h3>Search Users</h3>

<!-- Search Form -->
<select @bind="queryColumn">
    @foreach (var option in options)
    {
        <option value="@option">@option</option>
    }
</select>
<input @bind="searchTerm" placeholder="Enter search term" />
<button @onclick="SearchUsers">Search</button>

<!-- Search Results -->
@if (items != null && items.Any())
{
    <ul>
        @foreach (var result in items)
        {
            <li>
                <button class="btn btn-link" @onclick="() => OnResultClick(result)">
                    @result.First - @result.Last - @result.Major - @result.GradYear - @result.Company - @result.City
                </button>
            </li>
        }
    </ul>
}
else
{
    <p>No results found.</p>
}

<!-- Modal for Connection Request -->
@if (showModal)
{
    <div class="modal" tabindex="-1" style="display: block;" aria-hidden="false">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Connection Request</h5>
                    <button type="button" class="close" @onclick="CloseModal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Would you like to send a connection request to <strong>@selectedUser?.First @selectedUser?.Last</strong>?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">No</button>
                    <button type="button" class="btn btn-primary" @onclick="OpenConnectionForm">Yes</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal for Connection Request Form -->
@if (showConnectionForm)
{
    <div class="modal" tabindex="-1" style="display: block;" aria-hidden="false">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Send Connection Request Form</h5>
                    <button type="button" class="close" @onclick="CloseConnectionForm" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@connectionRequest" OnValidSubmit="HandleConnectionRequestSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label for="RequestSubject" class="form-label">Request Subject</label>
                            <InputText id="requestSubject" class="form-control" @bind-Value="connectionRequest.RequestSubject" />
                        </div>

                        <div class="mb-3">
                            <label for="message" class="form-label">Message</label>
                            <InputTextArea id="message" class="form-control" @bind-Value="connectionRequest.Message" />
                        </div>

                        <div class="mb-3">
                            <p>"You may only send one request per Alumni, make it count!"</p>
                            <button type="submit" class="btn btn-primary">Send Request</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Error Message Modal -->
@if (showErrorMessage)
{
    <div class="modal" tabindex="-1" style="display: block;" aria-hidden="false">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Error</h5>
                    <button type="button" class="close" @onclick="CloseErrorMessage" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <p>@errorText</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" @onclick="CloseErrorMessage">Confirm</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Confirmation Message Modal -->
@if (showConfirmationMessage)
{
    <div class="modal" tabindex="-1" style="display: block;" aria-hidden="false">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Success</h5>
                    <button type="button" class="close" @onclick="CloseConfirmationMessage" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Connection request sent successfully!</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" @onclick="CloseConfirmationMessage">Confirm</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const string DefaultValidationErrorText = "Error: Information not submitted. Please fill out all fields.";

    private string queryColumn = "First";
    private string[] options = { "First", "Last", "GradYear", "City", "Major", "Company" };
    private Alumni[]? items;
    private string searchTerm = string.Empty;

    private bool showModal = false;
    private bool showConnectionForm = false;
    private bool showErrorMessage = false;
    private bool showConfirmationMessage = false;
    private string errorText = DefaultValidationErrorText;
    private Alumni? selectedUser;
    private ConnectionRequest connectionRequest = new ConnectionRequest();
    private string? currentUserEmail;
    private Alumni? currentUser;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated != true)
        {
            return;
        }

        currentUserEmail = user.Identity.Name;
        if (string.IsNullOrEmpty(currentUserEmail))
        {
            return;
        }

        try
        {
            var result = await Supabase.GetData<Alumni>(currentUserEmail, "Email");
            currentUser = result.FirstOrDefault();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load current user profile for {Email}", currentUserEmail);
            errorText = "Could not load your profile. Please try again later.";
            showErrorMessage = true;
        }
    }

    protected async Task SearchUsers()
    {
        try
        {
            items = await Supabase.GetData<Alumni>(searchTerm, queryColumn);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Search failed for term {SearchTerm} on column {Column}", searchTerm, queryColumn);
            errorText = "Search failed. Please try again later.";
            showErrorMessage = true;
        }
    }

    private void OnResultClick(Alumni result)
    {
        selectedUser = result;
        showModal = true;
        StateHasChanged();
    }

    private void CloseModal()
    {
        showModal = false;
        StateHasChanged();
    }

    private void OpenConnectionForm()
    {
        showModal = false;
        showConnectionForm = true;
        StateHasChanged();
    }

    private void CloseConnectionForm()
    {
        showConnectionForm = false;
        StateHasChanged();
    }

    private void CloseErrorMessage()
    {
        showErrorMessage = false;
        StateHasChanged();
    }

    private void CloseConfirmationMessage()
    {
        showConfirmationMessage = false;
        StateHasChanged();
    }

    private async Task HandleConnectionRequestSubmit()
    {
        if (string.IsNullOrWhiteSpace(connectionRequest.RequestSubject) || string.IsNullOrWhiteSpace(connectionRequest.Message))
        {
            errorText = DefaultValidationErrorText;
            showErrorMessage = true;
            StateHasChanged();
            return;
        }

        if (selectedUser == null || currentUser == null)
        {
            errorText = "Could not determine your profile or the selected alumni. Please try again.";
            showErrorMessage = true;
            StateHasChanged();
            return;
        }

        try
        {
            var message = connectionRequest.Message;
            var body = $"{message}\n\nThe following request was sent on behalf of a WSU student ({currentUser.First} {currentUser.Last}) seeking a connection\nIf you would like to reply to the request their email address is: {currentUser.Email}\n\nTo be removed from this site and no longer recieve requests follow the link below";
            await EmailSender.SendEmailAsync(selectedUser.Email, $"Cougar Connect Request: {connectionRequest.RequestSubject}", body);

            await Supabase.AddConnection(selectedUser.Id, currentUser.Id);

            showConnectionForm = false;
            showConfirmationMessage = true;
            connectionRequest = new ConnectionRequest();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to send connection request from {CurrentUserId} to {SelectedUserId}", currentUser.Id, selectedUser.Id);
            errorText = "Could not send the connection request. Please try again later.";
            showErrorMessage = true;
        }

        StateHasChanged();
    }
}
