@page "/Connections"
@attribute [StreamRendering]
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using CougarConnect.Data
@using CougarConnect.Models
@using CougarConnect.Services
@inject UserManager<ApplicationUser> UserManager
@inject SupabaseService DBService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<Connections> Logger

<PageTitle>Connections</PageTitle>

<h1>Connections</h1>

<p>This is where you can view your sent connection requests.</p>

@if (errorMessage != null)
{
    <p class="text-danger">@errorMessage</p>
}

@if (allConnections == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <h2>Connections</h2>
    @if (allConnections.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Grad Year</th>
                    <th>City</th>
                    <th>Major</th>
                    <th>Company</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var connection in allConnections)
                {
                    <tr>
                        <td>@connection.First @connection.Last</td>
                        <td>@connection.GradYear</td>
                        <td>@connection.City</td>
                        <td>@connection.Major</td>
                        <td>@connection.Company</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No connections at the moment.</p>
    }
}

@code {
    private List<Alumni> allConnections = new List<Alumni>();
    private Alumni? currentUser;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity is not { IsAuthenticated: true, Name: { Length: > 0 } userName })
        {
            return;
        }

        try
        {
            var result = await DBService.GetData<Alumni>(userName, "Email");
            currentUser = result.FirstOrDefault();

            if (currentUser?.ConnectionList != null)
            {
                foreach (var connection in currentUser.ConnectionList)
                {
                    var connectionResult = await DBService.GetData<Alumni>(connection.ToString(), "id");
                    var match = connectionResult.FirstOrDefault();
                    if (match != null)
                    {
                        allConnections.Add(match);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load connections for {User}", user.Identity?.Name);
            errorMessage = "Could not load your connections. Please try again later.";
        }
    }
}
